---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Precios — GeneraIA">
  <main>
    <section class="hero min-h-[60vh] flex flex-col items-center justify-center text-center relative overflow-hidden bg-[#0a0a0a]">
      <!-- Floating particles -->
      <div class="particle-container absolute inset-0 z-0">
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
      </div>

      <div class="relative z-10 p-4 max-w-4xl mx-auto">
        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white leading-tight mb-4 font-space-grotesk"
          data-animate="fade-in-up"
        >
          Precios
        </h1>
        <p
          class="text-xl md:text-2xl text-gray-300 mb-8 font-dm-sans max-w-2xl mx-auto"
          data-animate="fade-in-up"
          data-animate-delay="0.2"
        >
          Sin sorpresas. Un solo plan, todo incluido.
        </p>
      </div>
    </section>

    <!-- Plan único -->
    <section class="py-20 bg-[#0a0a0a] text-white">
      <div class="max-w-lg mx-auto px-4">
        <div class="p-10 rounded-3xl bg-gradient-to-b from-gray-900 to-gray-900/50 border border-white/10 text-center relative overflow-hidden" data-animate="fade-in-up">
          <!-- Badge -->
          <span class="inline-block text-xs font-bold uppercase tracking-widest text-[#F59E0B] bg-[#F59E0B]/10 px-3 py-1 rounded-full mb-6">
            Plan único
          </span>

          <!-- Price -->
          <p class="text-6xl md:text-7xl font-extrabold text-white font-space-grotesk mb-2">
            149 <span class="text-2xl text-gray-400">€</span>
          </p>
          <p class="text-gray-500 text-sm mb-8">al mes · sin permanencia · sin setup</p>

          <!-- Features -->
          <ul class="text-left space-y-4 mb-10 max-w-sm mx-auto">
            <li class="flex items-start gap-3">
              <span class="text-[#F59E0B] mt-0.5">✓</span>
              <span class="text-gray-300 text-sm">Asistente IA para WhatsApp Business</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#F59E0B] mt-0.5">✓</span>
              <span class="text-gray-300 text-sm">Configuración y entrenamiento personalizado</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#F59E0B] mt-0.5">✓</span>
              <span class="text-gray-300 text-sm">Atención al cliente 24/7 automatizada</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#F59E0B] mt-0.5">✓</span>
              <span class="text-gray-300 text-sm">Captura de leads y agenda de citas</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#F59E0B] mt-0.5">✓</span>
              <span class="text-gray-300 text-sm">Panel de control con estadísticas</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-[#F59E0B] mt-0.5">✓</span>
              <span class="text-gray-300 text-sm">Soporte técnico continuo</span>
            </li>
          </ul>

          <!-- CTA -->
          <a
            href="https://wa.me/34681072103"
            target="_blank"
            class="btn bg-[#F59E0B] text-black px-8 py-3 rounded-lg font-bold text-lg hover:bg-opacity-80 transition duration-300 inline-block w-full"
          >
            Empezar 30 días gratis
          </a>
          <p class="text-gray-500 text-xs mt-3">Sin necesidad de tarjeta. Cancela cuando quieras.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 bg-[#0a0a0a] text-white" data-animate="fade-in-up">
      <h2 class="text-3xl font-bold mb-12 text-center font-space-grotesk">Preguntas frecuentes</h2>
      <div class="max-w-2xl mx-auto px-4 space-y-6">
        <div class="p-6 rounded-xl bg-gray-900/40 border border-white/5">
          <h3 class="font-bold mb-2 font-space-grotesk">¿Tengo que firmar un contrato?</h3>
          <p class="text-gray-400 text-sm leading-relaxed">No. No hay permanencia. Puedes cancelar cuando quieras, sin penalización.</p>
        </div>
        <div class="p-6 rounded-xl bg-gray-900/40 border border-white/5">
          <h3 class="font-bold mb-2 font-space-grotesk">¿Hay coste de instalación o setup?</h3>
          <p class="text-gray-400 text-sm leading-relaxed">No. La configuración, el entrenamiento de la IA y la integración con WhatsApp están incluidos.</p>
        </div>
        <div class="p-6 rounded-xl bg-gray-900/40 border border-white/5">
          <h3 class="font-bold mb-2 font-space-grotesk">¿Necesito conocimientos técnicos?</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Para nada. Nosotros hacemos toda la configuración. Tú solo nos dices qué necesitas y nosotros lo implementamos.</p>
        </div>
        <div class="p-6 rounded-xl bg-gray-900/40 border border-white/5">
          <h3 class="font-bold mb-2 font-space-grotesk">¿Los 30 días de prueba son gratis de verdad?</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Sí. Sin tarjeta de crédito. Durante 30 días tienes el asistente funcionando con tu negocio. Si no te convence, lo paramos sin coste.</p>
        </div>
        <div class="p-6 rounded-xl bg-gray-900/40 border border-white/5">
          <h3 class="font-bold mb-2 font-space-grotesk">¿Puedo probarlo antes de pagar?</h3>
          <p class="text-gray-400 text-sm leading-relaxed">Sí. Los 30 días gratis son una prueba real con tu negocio. No es una demo limitada. Queremos que veas los resultados antes de decidir.</p>
        </div>
      </div>
    </section>

    <!-- CTA final -->
    <section class="py-20 bg-[#0a0a0a] text-white text-center border-t border-white/5" data-animate="fade-in-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-space-grotesk">¿Hablamos?</h2>
      <p class="text-gray-400 text-lg mb-8 font-dm-sans">
        Cuéntanos tu negocio y te mostramos cómo funciona en 5 minutos.
      </p>
      <a
        href="https://wa.me/34681072103"
        target="_blank"
        class="btn bg-[#F59E0B] text-black px-8 py-3 rounded-lg font-bold text-lg hover:bg-opacity-80 transition duration-300 inline-block"
      >
        Escribirnos por WhatsApp
      </a>
    </section>
  </main>

  <style is:global>
    .particle-container {
      pointer-events: none;
      perspective: 500px;
    }
    .particle {
      position: absolute;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      animation: floatAndFade 15s infinite ease-in-out;
    }
    .particle:nth-child(1) { top: 10%; left: 10%; animation-duration: 12s; animation-delay: 0s; transform: scale(1.2); }
    .particle:nth-child(2) { top: 30%; left: 80%; animation-duration: 18s; animation-delay: 2s; transform: scale(0.8); }
    .particle:nth-child(3) { top: 60%; left: 20%; animation-duration: 15s; animation-delay: 4s; transform: scale(1.5); }
    .particle:nth-child(4) { top: 80%; left: 60%; animation-duration: 20s; animation-delay: 6s; transform: scale(0.9); }
    .particle:nth-child(5) { top: 40%; left: 40%; animation-duration: 10s; animation-delay: 8s; transform: scale(1.1); }
    @keyframes floatAndFade {
      0% { transform: translateY(0) rotate(0deg) scale(1) translateX(0); opacity: 0.5; }
      50% { transform: translateY(-50px) rotate(180deg) scale(1.5) translateX(20px); opacity: 0.8; }
      100% { transform: translateY(0) rotate(360deg) scale(1) translateX(0); opacity: 0.5; }
    }
    .btn {
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      font-weight: 600;
      text-decoration: none;
      display: inline-block;
    }
    [data-animate] { opacity: 0; transform: translateY(20px); }
    [data-animate="fade-in-up"] { transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
    [data-animate="fade-in-up"][data-animated] { opacity: 1; transform: translateY(0); }
    @media (max-width: 768px) {
      .hero h1 { font-size: clamp(2.5rem, 12vw, 4rem); }
      .hero p { font-size: 1.1rem; }
    }
  </style>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('[data-animate]');
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = entry.target.dataset.animateDelay || '0';
            setTimeout(() => entry.target.classList.add('data-animated'), parseFloat(delay) * 1000);
            obs.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px', threshold: 0.1 });
      elements.forEach(el => observer.observe(el));
    });
  </script>
</Layout>
