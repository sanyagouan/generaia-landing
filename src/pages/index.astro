---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GeneraIA - Tu negocio, atendido por IA">
    <main>
        <section class="hero min-h-screen flex flex-col items-center justify-center text-center relative overflow-hidden bg-[#0a0a0a]">
            <!-- Floating particles background -->
            <div class="particle-container absolute inset-0 z-0">
                <div class="particle bg-[#F59E0B] opacity-30"></div>
                <div class="particle bg-[#F59E0B] opacity-30"></div>
                <div class="particle bg-[#F59E0B] opacity-30"></div>
                <div class="particle bg-[#F59E0B] opacity-30"></div>
                <div class="particle bg-[#F59E0B] opacity-30"></div>
            </div>

            <div class="relative z-10 p-4 max-w-4xl mx-auto">
                <h1 
                    class="text-6xl md:text-8xl lg:text-9xl font-extrabold text-white leading-tight mb-4 font-space-grotesk viewport-filling-text" 
                    data-animate="fade-in-up"
                    style="font-size: 15vw; line-height: 0.9;"
                >
                    Tu negocio, <br class="md:hidden" />atendido por IA
                </h1>
                <p 
                    class="text-xl md:text-2xl text-gray-300 mb-8 font-dm-sans" 
                    data-animate="fade-in-up" 
                    data-animate-delay="0.2"
                >
                    Asistentes inteligentes por WhatsApp que responden, venden y fidelizan por ti
                </p>
                <div class="flex flex-col sm:flex-row justify-center gap-4" data-animate="fade-in-up" data-animate-delay="0.4">
                    <a href="#demo" class="btn btn-outline border-[#F59E0B] text-[#F59E0B] hover:bg-[#F59E0B] hover:text-black transition duration-300">
                        Ver demo
                    </a>
                    <a href="https://wa.me/34681072103" target="_blank" class="btn bg-[#F59E0B] text-black hover:bg-opacity-80 transition duration-300">
                        Hablar con nosotros
                    </a>
                </div>
            </div>
        </section>

        <!-- ===== CONFIANZA (HONESTA) ===== -->
        <section class="trusted-by py-16 bg-[#0a0a0a] text-white text-center" data-animate="fade-in-up">
            <h2 class="text-3xl font-bold mb-4 font-space-grotesk">Sin permanencia. Sin setup. Sin riesgo.</h2>
            <p class="text-gray-400 text-lg max-w-xl mx-auto mb-8 font-dm-sans">
                30 días gratis, sin necesidad de tarjeta. Configuramos todo por ti y te enseñamos cómo funciona.
            </p>
            <a href="https://wa.me/34681072103" target="_blank" class="btn bg-[#F59E0B] text-black hover:bg-opacity-80 transition duration-300 font-bold text-lg">
                Quiero probarlo gratis
            </a>
        </section>

        <!-- ===== CÓMO FUNCIONA ===== -->
        <section class="py-16 bg-[#0a0a0a] text-white" data-animate="fade-in-up">
            <h2 class="text-3xl font-bold mb-12 text-center font-space-grotesk">Cómo funciona</h2>
            <div class="max-w-5xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-8">
                <div class="p-6 bg-gray-900/60 rounded-xl text-center" data-animate="fade-in-up" data-animate-delay="0.2">
                    <p class="text-4xl mb-3">🔌</p>
                    <h3 class="text-xl font-bold mb-2 font-space-grotesk">Conectamos tu WhatsApp</h3>
                    <p class="text-gray-400 text-sm">Integramos la IA con tu WhatsApp Business. Tú no mueves un dedo.</p>
                </div>
                <div class="p-6 bg-gray-900/60 rounded-xl text-center" data-animate="fade-in-up" data-animate-delay="0.4">
                    <p class="text-4xl mb-3">🧠</p>
                    <h3 class="text-xl font-bold mb-2 font-space-grotesk">Entiende tu negocio</h3>
                    <p class="text-gray-400 text-sm">Entrenamos la IA con tu información, servicios y horarios.</p>
                </div>
                <div class="p-6 bg-gray-900/60 rounded-xl text-center" data-animate="fade-in-up" data-animate-delay="0.6">
                    <p class="text-4xl mb-3">💬</p>
                    <h3 class="text-xl font-bold mb-2 font-space-grotesk">Empieza a vender 24/7</h3>
                    <p class="text-gray-400 text-sm">Tu asistente atiende clientes, capta leads y agenda citas sin descanso.</p>
                </div>
            </div>
            <div class="text-center mt-8">
                <a href="/como-funciona" class="text-[#F59E0B] hover:underline font-dm-sans">Ver detalle completo →</a>
            </div>
        </section>

        <!-- ===== PRECIO ===== -->
        <section class="py-16 bg-[#0a0a0a] text-white text-center" data-animate="fade-in-up">
            <h2 class="text-3xl font-bold mb-4 font-space-grotesk">149 €/mes</h2>
            <p class="text-gray-400 text-lg mb-2 font-dm-sans">Sin permanencia. Sin coste de setup.</p>
            <p class="text-gray-500 text-sm mb-8 font-dm-sans">Incluye configuración, entrenamiento y soporte continuo.</p>
            <a href="/precios" class="text-[#F59E0B] hover:underline font-dm-sans">Ver planes →</a>
        </section>

        <!-- ===== DEMO INTERACTIVA ===== -->
        <section id="demo" class="quick-demo py-16 bg-[#0a0a0a] text-white text-center flex flex-col items-center" data-animate="fade-in-up">
            <h2 class="text-3xl font-bold mb-12 font-space-grotesk">Demo rápida</h2>
            <div class="whatsapp-chat-preview bg-white rounded-lg p-4 shadow-xl w-full max-w-md mx-auto" data-animate="fade-in-up" data-animate-delay="1.2">
                <div class="chat-header bg-[#F59E0B] text-black p-3 rounded-t-lg font-bold">
                    Asistente GeneraIA
                </div>
                <div class="chat-body p-4 bg-gray-100 dark:bg-gray-800 rounded-b-lg flex flex-col gap-3">
                    <div class="message received bg-gray-300 text-black p-2 rounded-lg self-start max-w-[80%]" data-animate="fade-in-left" data-animate-delay="1.4">
                        Hola, estoy interesado en sus servicios de IA.
                    </div>
                    <div class="message sent bg-[#F59E0B] text-black p-2 rounded-lg self-end max-w-[80%]" data-animate="fade-in-right" data-animate-delay="1.6">
                        ¡Claro! ¿En qué puedo ayudarte hoy? ¿Buscas automatizar ventas o soporte?
                    </div>
                    <div class="message received bg-gray-300 text-black p-2 rounded-lg self-start max-w-[80%]" data-animate="fade-in-left" data-animate-delay="1.8">
                        Quisiera saber más sobre cómo pueden ayudarme a vender más.
                    </div>
                </div>
            </div>
        </section>
    </main>

    <style is:global>
        /* Base styles from Warm Tech design system */
        html {
            background-color: #0a0a0a; /* Dark base */
            color: #fff;
        }
        body {
            font-family: 'DM Sans', sans-serif; /* Body font */
        }
        h1, h2, h3, h4, h5, h6 {
            font-family: 'Space Grotesk', sans-serif; /* Display font */
        }

        /* Viewport-filling typography for main title */
        .viewport-filling-text {
            font-size: clamp(3rem, 10vw + 1rem, 10rem); /* Responsive font size */
        }

        /* CTAs */
        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
        }
        .btn-outline {
            border: 2px solid;
            background: transparent;
        }
        .btn-filled {
            background-color: #F59E0B;
            color: black;
        }

        /* Particle animations */
        .particle-container {
            pointer-events: none;
            perspective: 500px;
        }
        .particle {
            position: absolute;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            animation: floatAndFade 15s infinite ease-in-out;
        }

        .particle:nth-child(1) { top: 10%; left: 10%; animation-duration: 12s; animation-delay: 0s; transform: scale(1.2); }
        .particle:nth-child(2) { top: 30%; left: 80%; animation-duration: 18s; animation-delay: 2s; transform: scale(0.8); }
        .particle:nth-child(3) { top: 60%; left: 20%; animation-duration: 15s; animation-delay: 4s; transform: scale(1.5); }
        .particle:nth-child(4) { top: 80%; left: 60%; animation-duration: 20s; animation-delay: 6s; transform: scale(0.9); }
        .particle:nth-child(5) { top: 40%; left: 40%; animation-duration: 10s; animation-delay: 8s; transform: scale(1.1); }

        @keyframes floatAndFade {
            0% {
                transform: translateY(0) rotate(0deg) scale(1) translateX(0);
                opacity: 0.5;
            }
            50% {
                transform: translateY(-50px) rotate(180deg) scale(1.5) translateX(20px);
                opacity: 0.8;
            }
            100% {
                transform: translateY(0) rotate(360deg) scale(1) translateX(0);
                opacity: 0.5;
            }
        }

        /* WhatsApp chat preview (simplified for demo) */
        .whatsapp-chat-preview {
            background: #e5ddd5; /* Light background for chat area */
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            font-family: 'DM Sans', sans-serif;
            overflow: hidden;
        }

        .whatsapp-chat-preview .chat-header {
            background-color: #075E54;
            color: white;
            padding: 10px;
            font-weight: bold;
            text-align: left;
        }
        .whatsapp-chat-preview .chat-body {
            padding: 15px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            background-color: #ece5dd; /* WhatsApp chat background */
        }
        .whatsapp-chat-preview .message {
            max-width: 75%;
            padding: 8px 12px;
            border-radius: 10px;
            text-align: left;
            word-wrap: break-word;
            box-shadow: 0 1px 0.5px rgba(0,0,0,0.13);
        }
        .whatsapp-chat-preview .message.received {
            background-color: #ffffff;
            align-self: flex-start;
        }
        .whatsapp-chat-preview .message.sent {
            background-color: #DCF8C6; /* WhatsApp green */
            align-self: flex-end;
        }

        /* Basic stagger reveal animations (placeholder, assuming GSAP for real implementation) */
        [data-animate] {
            opacity: 0;
            transform: translateY(20px);
        }
        [data-animate="fade-in-up"] {
            transition: opacity 0.6s ease-out, transform 0.6s ease-out;
        }
        [data-animate="fade-in-up"][data-animated] {
            opacity: 1;
            transform: translateY(0);
        }
        /* Add more specific rules for different animation types or use a JS library */

        /* Mobile responsiveness adjustments */
        @media (max-width: 768px) {
            .hero h1 {
                font-size: clamp(3rem, 15vw, 5rem);
            }
            .hero p {
                font-size: 1.1rem;
            }
            .hero .flex-col {
                flex-direction: column;
            }
            .hero .btn {
                width: 100%;
            }
            .stats .grid-cols-3 {
                grid-template-columns: 1fr;
            }
            .whatsapp-chat-preview {
                max-width: 95%;
            }
        }
    </style>
    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const elements = document.querySelectorAll('[data-animate]');
            const observer = new IntersectionObserver((entries, observer) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const delay = entry.target.dataset.animateDelay || '0';
                        setTimeout(() => {
                            entry.target.classList.add('data-animated');
                        }, parseFloat(delay) * 1000);
                        observer.unobserve(entry.target);
                    }
                });
            }, {
                rootMargin: '0px',
                threshold: 0.1
            });

            elements.forEach(element => {
                observer.observe(element);
            });
        });
    </script>
</Layout>
