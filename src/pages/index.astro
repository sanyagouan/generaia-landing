        <div class="flex items-center gap-4 text-sm">
            <a href="#como-funciona" class="text-[#888] hover:text-[#e5e5e5] transition hidden sm:block">Cómo funciona</a>
            <a href="#precio" class="text-[#888] hover:text-[#e5e5e5] transition hidden sm:block">Precio</a>
            <a href="https://wa.me/34681072103?text=Hola%2C%20quiero%20saber%20m%C3%A1s%20sobre%20GeneraIA" target="_blank" rel="noopener" class="bg-[#f59e0b] text-[#0f0e0c] px-4 py-2 rounded-lg font-medium text-sm hover:brightness-110 transition">Pruébalo gratis</a>
