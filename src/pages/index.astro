---
// GeneraIA Landing - Honest Design
// v2 - Sin estadísticas falsas, sin testimonios inventados
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GeneraIA - Asistente WhatsApp con IA para tu negocio</title>
    <meta name="description" content="Configuro un asistente de WhatsApp con IA para tu negocio en menos de 48 horas. Sin permanencia. Sin setup. 149€/mes." />

    <link href="https://api.fontshare.com/v2/css?f[]=satoshi@700,500,400,300&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Satoshi', 'Inter', 'sans-serif'],
                    },
                    colors: {
                        amber: { 500: '#f59e0b' },
                    },
                    animation: {
                        'typewriter': 'typewriter 2s steps(40) 1s forwards',
                        'blink': 'blink 1s step-end infinite',
                        'slide-up': 'slideUp 0.6s ease-out forwards',
                        'fade-in': 'fadeIn 1s ease-out forwards',
                    },
                    keyframes: {
                        typewriter: {
                            to: { width: '100%' },
                        },
                        blink: {
                            '50%': { borderColor: 'transparent' },
                        },
                        slideUp: {
                            from: { opacity: 0, transform: 'translateY(30px)' },
                            to: { opacity: 1, transform: 'translateY(0)' },
                        },
                        fadeIn: {
                            from: { opacity: 0 },
                            to: { opacity: 1 },
                        },
                    },
                },
            },
        }
    </script>
    <style>
        :root {
            --bg: #0f0e0c;
            --card: #1a1916;
            --border: #2a2924;
            --accent: #f59e0b;
            --text: #e5e5e5;
            --muted: #888;
        }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Satoshi', 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.6;
        }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--accent); border-radius: 3px; }

        .typewriter-line {
            display: inline;
            overflow: hidden;
            white-space: nowrap;
            border-right: 2px solid var(--accent);
            width: 0;
            animation: typewriter 1.5s steps(40) forwards, blink 0.8s step-end infinite;
        }
        .typewriter-line:nth-child(1) { animation-delay: 0.5s; }
        .typewriter-line:nth-child(2) { animation-delay: 2.5s; width: 0; }
        .typewriter-line:nth-child(3) { animation-delay: 4.5s; width: 0; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        .tab-content {
            display: none;
        }
        .tab-content.active {
            display: block;
            animation: fadeIn 0.4s ease-out;
        }
        .tab-btn.active {
            color: var(--accent);
            border-bottom: 2px solid var(--accent);
        }

        /* Chat bubble animation */
        .chat-msg {
            opacity: 1;
        }
        .chat-msg:nth-child(1) { animation: fadeIn 0.5s ease-out 0.2s both; }
        .chat-msg:nth-child(2) { animation: fadeIn 0.5s ease-out 0.8s both; }
        .chat-msg:nth-child(3) { animation: fadeIn 0.5s ease-out 1.4s both; }
        .chat-msg:nth-child(4) { animation: fadeIn 0.5s ease-out 2.0s both; }
        .chat-msg:nth-child(5) { animation: fadeIn 0.5s ease-out 2.6s both; }
        .chat-msg:nth-child(6) { animation: fadeIn 0.5s ease-out 3.2s both; }
        .chat-msg:nth-child(7) { animation: fadeIn 0.5s ease-out 3.8s both; }
    </style>
</head>
<body class="antialiased">

<!-- ============================== -->
<!-- NAV -->
<!-- ============================== -->
<nav class="fixed top-0 left-0 w-full z-50 bg-[#0f0e0c]/80 backdrop-blur-md border-b border-[#2a2924]/50">
