---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- HERO: Chat interactivo como protagonista -->
  <section class="pt-24 pb-16 px-6 min-h-screen flex flex-col justify-center" style="position:relative;overflow:hidden">
    <!-- Gradient mesh background -->
    <div style="position:absolute;inset:0;z-index:0;pointer-events:none">
      <div style="position:absolute;top:-20%;right:-10%;width:60%;height:60%;background:radial-gradient(circle,rgba(245,158,11,0.12) 0%,transparent 70%);border-radius:50%"></div>
      <div style="position:absolute;bottom:-10%;left:-10%;width:50%;height:50%;background:radial-gradient(circle,rgba(245,158,11,0.08) 0%,transparent 70%);border-radius:50%"></div>
      <div style="position:absolute;top:40%;left:30%;width:40%;height:40%;background:radial-gradient(circle,rgba(180,83,9,0.06) 0%,transparent 70%);border-radius:50%"></div>
    </div>

    <div style="position:relative;z-index:1;max-width:1200px;margin:0 auto;width:100%">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">

        <!-- Left: Copy -->
        <div>
          <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem">
            <div class="pulse-ring"></div>
            <span style="color:var(--accent);font-size:0.85rem;font-weight:600;letter-spacing:0.05em">
              DEMO EN VIVO — PRUÉBALO AHORA
            </span>
          </div>

          <h1 style="font-size:clamp(2.5rem,5vw,4rem);font-weight:700;line-height:1.05;margin-bottom:1.5rem;font-family:var(--font-display)">
            Tu WhatsApp<br>
            <span style="background:linear-gradient(135deg,#f59e0b,#d97706,#f59e0b);-webkit-background-clip:text;-webkit-text-fill-color:transparent">atiende solo</span>.<br>
            Tú ni lo tocas.
          </h1>

          <p style="font-size:1.1rem;color:var(--muted);line-height:1.6;margin-bottom:2rem;max-width:480px">
            Conectamos una IA a tu WhatsApp en 48h. Atiende clientes, capta leads, agenda citas — 
            <strong style="color:var(--text)">sin que instales nada</strong>. 
            30 días gratis.
          </p>

          <div style="display:flex;gap:1rem;flex-wrap:wrap">
            <a href="#chat" style="display:inline-flex;align-items:center;gap:0.5rem;background:var(--accent);color:var(--bg);padding:0.85rem 1.75rem;border-radius:12px;font-weight:700;font-size:1rem;text-decoration:none;box-shadow:0 4px 20px rgba(245,158,11,0.3);transition:all 0.2s" 
               onmouseover="this.style.filter='brightness(1.1)';this.style.transform='translateY(-2px)'"
               onmouseout="this.style.filter='';this.style.transform=''">
              Probar gratis 30 días →
            </a>
            <a href="#como-funciona" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.85rem 1.75rem;border-radius:12px;font-weight:600;font-size:1rem;text-decoration:none;border:1px solid var(--border);color:var(--text);transition:all 0.2s"
               onmouseover="this.style.borderColor='rgba(245,158,11,0.3)'"
               onmouseout="this.style.borderColor=''">
              Ver cómo funciona
            </a>
          </div>

          <p style="margin-top:1.5rem;font-size:0.8rem;color:var(--muted)">
            Sin permanencia · Sin setup · 30 días de prueba sin tarjeta
          </p>
        </div>

        <!-- Right: Interactive Chat Widget -->
        <div id="chat" style="background:rgba(26,25,22,0.6);backdrop-filter:blur(16px);border:1px solid var(--border);border-radius:20px;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,0.4)">
          <!-- Chat header -->
          <div style="background:linear-gradient(135deg,#1a1916,#2a2924);padding:1rem 1.25rem;display:flex;align-items:center;gap:0.75rem;border-bottom:1px solid var(--border)">
            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:#0f0e0c;font-family:var(--font-display)">G</div>
            <div style="flex:1">
              <div style="font-weight:600;font-size:0.9rem;color:var(--text)">Asistente GeneraIA</div>
              <div style="display:flex;align-items:center;gap:0.35rem;font-size:0.75rem">
                <span style="width:6px;height:6px;border-radius:50%;background:#22c55e;display:inline-block"></span>
                <span style="color:#22c55e">En línea</span>
                <span style="color:var(--muted)">· Demo interactiva</span>
              </div>
            </div>
          </div>

          <!-- Chat messages -->
          <div id="chat-messages" style="padding:1.25rem;min-height:340px;max-height:380px;overflow-y:auto;display:flex;flex-direction:column;gap:0.75rem;background:rgba(10,10,9,0.8)">
            <div class="chat-bubble received">
              ¡Hola! Soy el asistente de GeneraIA. ¿Quieres ver cómo funciona? Pregúntame lo que quieras 😊
            </div>
          </div>

          <!-- Chat input -->
          <div style="padding:0.75rem 1rem;border-top:1px solid var(--border);display:flex;gap:0.5rem;background:rgba(26,25,22,0.8)">
            <input id="chat-input" type="text" placeholder="Escribe aquí tu mensaje..."
                   style="flex:1;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:0.7rem 1rem;color:var(--text);font-size:0.9rem;outline:none">
            <button id="chat-send" onclick="sendChat()"
                    style="background:var(--accent);color:var(--bg);border:none;border-radius:10px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.1rem;transition:all 0.2s"
                    onmouseover="this.style.filter='brightness(1.1)'"
                    onmouseout="this.style.filter=''">
              →
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CÓMO FUNCIONA (simplificado, sin contradicciones) -->
  <section id="como-funciona" class="py-20 px-6" style="background:var(--card)">
    <div class="max-w-5xl mx-auto">
      <h2 style="font-size:2rem;font-weight:700;text-align:center;margin-bottom:0.5rem;font-family:var(--font-display)">
        Así de simple
      </h2>
      <p style="color:var(--muted);text-align:center;margin-bottom:3rem;max-width:500px;margin-left:auto;margin-right:auto">
        Conectamos una IA a tu WhatsApp. Tú no tocas nada técnico.
      </p>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:2rem">
        <div style="text-align:center;padding:1.5rem">
          <div style="width:48px;height:48px;border-radius:16px;background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(217,119,6,0.05));border:1px solid rgba(245,158,11,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.3rem;font-weight:700;color:var(--accent);font-family:var(--font-display)">1</div>
          <h3 style="font-weight:700;margin-bottom:0.5rem">Cuéntanos qué haces</h3>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.5">15 minutos por WhatsApp. Nos explicas tu negocio, cómo respondes, qué automatizar.</p>
        </div>
        <div style="text-align:center;padding:1.5rem">
          <div style="width:48px;height:48px;border-radius:16px;background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(217,119,6,0.05));border:1px solid rgba(245,158,11,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.3rem;font-weight:700;color:var(--accent);font-family:var(--font-display)">2</div>
          <h3 style="font-weight:700;margin-bottom:0.5rem">Tu WhatsApp se vuelve inteligente</h3>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.5">No instales nada. La IA empieza a atender clientes en tu número. Responde, captura leads, agenda.</p>
        </div>
        <div style="text-align:center;padding:1.5rem">
          <div style="width:48px;height:48px;border-radius:16px;background:linear-gradient(135deg,rgba(245,158,11,0.15),rgba(217,119,6,0.05));border:1px solid rgba(245,158,11,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;font-size:1.3rem;font-weight:700;color:var(--accent);font-family:var(--font-display)">3</div>
          <h3 style="font-weight:700;margin-bottom:0.5rem">Tú solo ves los leads</h3>
          <p style="color:var(--muted);font-size:0.9rem;line-height:1.5">Cada cliente interesado aparece en tu panel. 149€/mes, sin permanencia, sin sorpresas.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRECIO -->
  <section id="precios" class="py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 style="font-size:2rem;font-weight:700;margin-bottom:0.5rem;font-family:var(--font-display)">Un precio. Sin sorpresas.</h2>
      <p style="color:var(--muted);margin-bottom:2.5rem">Sin setup. Sin permanencia. Cancela cuando quieras.</p>

      <div style="display:inline-block;background:linear-gradient(135deg,var(--card),var(--bg));border:2px solid rgba(245,158,11,0.3);border-radius:20px;padding:2.5rem;text-align:center;min-width:320px">
        <div style="font-size:0.8rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted);margin-bottom:0.5rem">Plan único</div>
        <div style="font-size:3rem;font-weight:700;color:var(--accent);font-family:var(--font-display)">149€<span style="font-size:1.25rem;color:var(--muted);font-weight:400">/mes</span></div>
        <div style="color:var(--muted);font-size:0.85rem;margin:0.5rem 0 1.5rem">30 días gratis · Sin tarjeta · Sin compromiso</div>

        <ul style="list-style:none;text-align:left;margin-bottom:2rem;display:inline-block">
          <li style="padding:0.4rem 0;display:flex;align-items:center;gap:0.5rem;font-size:0.9rem">✓ <span>Atención 24/7 en tu WhatsApp</span></li>
          <li style="padding:0.4rem 0;display:flex;align-items:center;gap:0.5rem;font-size:0.9rem">✓ <span>Captura automática de leads</span></li>
          <li style="padding:0.4rem 0;display:flex;align-items:center;gap:0.5rem;font-size:0.9rem">✓ <span>Panel CRM en tiempo real</span></li>
          <li style="padding:0.4rem 0;display:flex;align-items:center;gap:0.5rem;font-size:0.9rem">✓ <span>Soporte directo por WhatsApp</span></li>
          <li style="padding:0.4rem 0;display:flex;align-items:center;gap:0.5rem;font-size:0.9rem">✓ <span>Sin límite de conversaciones</span></li>
        </ul>

        <a href="https://wa.me/34681072103?text=Hola%2C%20quiero%20empezar%20los%2030%20d%C3%ADas%20gratis" target="_blank" rel="noopener"
           style="display:inline-block;background:var(--accent);color:var(--bg);padding:1rem 2rem;border-radius:12px;font-weight:700;font-size:1.1rem;text-decoration:none;box-shadow:0 4px 20px rgba(245,158,11,0.3)">
          Empezar 30 días gratis →
        </a>
        <p style="margin-top:0.75rem;font-size:0.8rem;color:var(--muted)">Hablas con Santi, el fundador. Sin bots, sin formularios.</p>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-24 px-6 text-center" style="background:linear-gradient(180deg,var(--bg) 0%,var(--card) 100%)">
    <div class="max-w-2xl mx-auto">
      <h2 style="font-size:2.5rem;font-weight:700;margin-bottom:1rem;font-family:var(--font-display);line-height:1.1">
        ¿Tienes 15 minutos?
      </h2>
      <p style="color:var(--muted);font-size:1.1rem;margin-bottom:2rem;line-height:1.5">
        Cuéntame cómo es tu negocio. Si puedo ayudarte, te configuro el asistente gratis durante 30 días.
      </p>
      <a href="https://wa.me/34681072103?text=Hola%2C%20quiero%20saber%20si%20GeneraIA%20es%20para%20mi" target="_blank" rel="noopener"
         style="display:inline-block;background:var(--accent);color:var(--bg);padding:1rem 2.5rem;border-radius:12px;font-weight:700;font-size:1.1rem;text-decoration:none;box-shadow:0 4px 20px rgba(245,158,11,0.3)">
        Escribir por WhatsApp →
      </a>
      <p style="margin-top:1rem;font-size:0.85rem;color:var(--muted)">o <a href="mailto:hola@generaia.org" style="color:var(--text);text-decoration:underline">hola@generaia.org</a></p>
    </div>
  </section>

  <!-- Chat script -->
  <script is:inline>
    window.sendChat = async function() {
      const chatMessages = document.getElementById('chat-messages');
      const chatInput = document.getElementById('chat-input');
      const msg = chatInput.value.trim();
      if (!msg) return;
      chatInput.value = '';
      addMessage(msg, 'user');

      document.getElementById('chat-send').disabled = true;

      try {
        const r = await fetch('/api/chat', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({message: msg})
        });
        const data = await r.json();
        if (data.response) {
          addMessage(data.response, 'assistant');
        } else {
          addMessage('(Error de conexión. Inténtalo de nuevo)', 'assistant');
        }
      } catch(e) {
        addMessage('(Error de conexión. Inténtalo de nuevo)', 'assistant');
      }

      document.getElementById('chat-send').disabled = false;
    };

    function addMessage(text, role) {
      const chatMessages = document.getElementById('chat-messages');
      const bubble = document.createElement('div');
      bubble.className = role === 'user' ? 'chat-bubble sent' : 'chat-bubble received';
      bubble.textContent = text;
      chatMessages.appendChild(bubble);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    document.addEventListener('DOMContentLoaded', function() {
      const input = document.getElementById('chat-input');
      if (input) {
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            window.sendChat();
          }
        });
      }
      // Welcome hint
      setTimeout(function() {
        addMessage('Puedes preguntarme: ¿qué es GeneraIA?, ¿cuánto cuesta?, ¿cómo funciona...?', 'assistant');
      }, 1000);
    });
  </script>

  <style>
    .chat-bubble {
      max-width: 80%;
      padding: 0.65rem 1rem;
      border-radius: 16px;
      font-size: 0.9rem;
      line-height: 1.45;
      animation: fadeUp 0.3s ease-out;
    }
    .chat-bubble.received {
      background: linear-gradient(135deg, #1a1916, #222120);
      border: 1px solid var(--border);
      align-self: flex-start;
      border-bottom-left-radius: 4px;
      color: var(--text);
    }
    .chat-bubble.sent {
      background: linear-gradient(135deg, rgba(245,158,11,0.2), rgba(217,119,6,0.1));
      border: 1px solid rgba(245,158,11,0.2);
      align-self: flex-end;
      border-bottom-right-radius: 4px;
      color: var(--text);
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    #chat-messages::-webkit-scrollbar { width: 4px; }
    #chat-messages::-webkit-scrollbar-track { background: transparent; }
    #chat-messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    @media (max-width: 768px) {
      section > div > div { grid-template-columns: 1fr !important; }
    }
  </style>
</Layout>
