---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- ============================= -->
  <!-- NAV -->
  <!-- ============================= -->
  <nav class="fixed top-0 left-0 w-full z-50 bg-bg/80 backdrop-blur-md border-b border-border/50">
    <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="12" stroke="#f59e0b" stroke-width="2" fill="none"/>
          <text x="16" y="22" text-anchor="middle" fill="#f59e0b" font-size="18" font-weight="700" font-family="Space Grotesk, sans-serif">G</text>
          <path d="M28 8 Q32 4 28 0" stroke="#f59e0b" stroke-width="1.5" fill="none" opacity="0.7"/>
        </svg>
        <span class="text-lg font-bold tracking-tight font-display">Genera<span class="text-accent">IA</span></span>
      </a>
      <div class="flex items-center gap-6 text-sm">
        <a href="/" class="text-accent font-medium">Inicio</a>
        <a href="/como-funciona" class="text-muted hover:text-text transition hidden sm:block">Cómo funciona</a>
        <a href="/sectores" class="text-muted hover:text-text transition hidden sm:block">Sectores</a>
        <a href="/precios" class="text-muted hover:text-text transition hidden sm:block">Precios</a>
        <a href="https://wa.me/34681072103?text=Hola%2C%20quiero%20saber%20m%C3%A1s%20sobre%20GeneraIA" target="_blank" rel="noopener" class="bg-accent text-bg px-4 py-2 rounded-lg font-medium text-sm hover:brightness-110 transition">Pruébalo gratis</a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="sm:hidden text-muted hover:text-text" aria-label="Menú">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden border-t border-border bg-bg/95 backdrop-blur-xl">
      <div class="px-6 py-4 flex flex-col gap-4">
        <a href="/" class="text-accent font-medium">Inicio</a>
        <a href="/como-funciona" class="text-muted hover:text-text transition">Cómo funciona</a>
        <a href="/sectores" class="text-muted hover:text-text transition">Sectores</a>
        <a href="/precios" class="text-muted hover:text-text transition">Precios</a>
      </div>
    </div>
  </nav>

  <!-- ============================= -->
  <!-- HERO -->
  <!-- ============================= -->
  <section class="pt-28 pb-20 px-6 max-w-5xl mx-auto">
    <div class="text-center max-w-3xl mx-auto animate-slide-up">
      <h1 class="text-4xl md:text-6xl font-bold leading-tight tracking-tight mb-6">
        Tu negocio atiende solo,<br />
        <span class="text-accent">tú descansas</span>
      </h1>
      <p class="text-lg md:text-xl text-muted mb-10 max-w-2xl mx-auto leading-relaxed">
        Configuro un asistente de WhatsApp con IA para tu negocio en menos de 48 horas. Responde clientes, captura leads y agenda citas — sin que tú hagas nada.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://wa.me/34681072103" target="_blank" rel="noopener" class="bg-accent text-bg px-8 py-4 rounded-xl font-bold text-lg hover:brightness-110 transition shadow-lg shadow-accent/20">
          Pruébalo gratis 30 días →
        </a>
        <a href="#demo" class="text-text px-8 py-4 rounded-xl font-medium text-lg border border-border hover:border-accent/50 transition">
          Ver cómo funciona
        </a>
      </div>
      <p class="text-sm text-muted mt-4">
        Sin permanencia. Sin setup. Cancela cuando quieras. <strong class="text-text">149€/mes.</strong>
      </p>
    </div>
  </section>

  <!-- ============================= -->
  <!-- CÓMO FUNCIONA (3 pasos) -->
  <!-- ============================= -->
  <section id="como-funciona" class="py-20 px-6 max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4 animate-fade-in">Yo me encargo de todo</h2>
    <p class="text-muted text-center mb-16 max-w-xl mx-auto">Sin apps, sin configuraciones técnicas. Tú solo hablas conmigo.</p>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-card border border-border rounded-2xl p-8 text-center animate-slide-up">
        <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
          <span class="text-accent font-bold text-xl">1</span>
        </div>
        <h3 class="text-xl font-bold mb-3">Me cuentas tu negocio (15 min)</h3>
        <p class="text-muted leading-relaxed">Una llamada rápida. Me explicas qué preguntas te hacen siempre, cómo quieres responder, qué necesitas automatizar.</p>
      </div>
      <div class="bg-card border border-border rounded-2xl p-8 text-center animate-slide-up" style="view-transition-name: step2">
        <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
          <span class="text-accent font-bold text-xl">2</span>
        </div>
        <h3 class="text-xl font-bold mb-3">Configuro tu asistente (48h)</h3>
        <p class="text-muted leading-relaxed">Entreno la IA con la información de tu negocio. Tono, respuestas, flujos. Tú no tocas nada.</p>
      </div>
      <div class="bg-card border border-border rounded-2xl p-8 text-center animate-slide-up" style="view-transition-name: step3">
        <div class="w-12 h-12 rounded-full bg-accent/10 border border-accent/20 flex items-center justify-center mx-auto mb-6">
          <span class="text-accent font-bold text-xl">3</span>
        </div>
        <h3 class="text-xl font-bold mb-3">Tu WhatsApp atiende solo</h3>
        <p class="text-muted leading-relaxed">Desde el día 3, cada mensaje que llega a tu WhatsApp lo gestiona la IA. Tú solo ves los leads en tu panel.</p>
      </div>
    </div>
  </section>

  <!-- ============================= -->
  <!-- DEMO INTERACTIVA WHATSAPP -->
  <!-- ============================= -->
  <section id="demo" class="py-20 px-6 bg-card/50 border-y border-border/50">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Prueba el asistente ahora mismo</h2>
      <p class="text-muted text-center mb-12 max-w-xl mx-auto">Esto es exactamente lo que verían tus clientes al escribirte.</p>

      <!-- WhatsApp Mock -->
      <div class="bg-[#0a0a09] rounded-2xl border border-border max-w-md mx-auto overflow-hidden shadow-xl shadow-black/40">
        <div class="bg-card px-4 py-3 flex items-center gap-3 border-b border-border">
          <div class="w-8 h-8 rounded-full bg-accent/20 flex items-center justify-center text-xs font-bold text-accent">G</div>
          <div>
            <p class="font-medium text-sm">Asistente GeneraIA</p>
            <p class="text-xs text-green-500">● en línea</p>
          </div>
        </div>
        <div class="p-4 space-y-3 min-h-[380px] bg-bg">
          <div class="chat-msg flex">
            <div class="bg-card border border-border rounded-2xl rounded-bl-sm px-4 py-2.5 max-w-[85%]">
              <p class="text-sm">Hola, ¿tenéis mesa para esta noche?</p>
            </div>
          </div>
          <div class="chat-msg flex justify-end">
            <div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-4 py-2.5 max-w-[85%]">
              <p class="text-sm">¡Hola! Claro 😊 ¿Para cuántas personas y a qué hora?</p>
            </div>
          </div>
          <div class="chat-msg flex">
            <div class="bg-card border border-border rounded-2xl rounded-bl-sm px-4 py-2.5 max-w-[85%]">
              <p class="text-sm">Para 4, sobre las 21h</p>
            </div>
          </div>
          <div class="chat-msg flex justify-end">
            <div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-4 py-2.5 max-w-[85%]">
              <p class="text-sm">Perfecto, tenemos disponibilidad. ¿Me das tu nombre y un teléfono de contacto?</p>
            </div>
          </div>
          <div class="chat-msg flex">
            <div class="bg-card border border-border rounded-2xl rounded-bl-sm px-4 py-2.5 max-w-[85%]">
              <p class="text-sm">Soy Pedro, 612 345 678</p>
            </div>
          </div>
          <div class="chat-msg flex justify-end">
            <div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-4 py-2.5 max-w-[85%]">
              <p class="text-sm">¡Reserva confirmada, Pedro! Te esperamos esta noche a las 21h. ¿Alguna alergia o preferencia?</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-8">
        <a href="https://wa.me/34681072103" target="_blank" rel="noopener" class="inline-block bg-accent text-bg px-8 py-4 rounded-xl font-bold text-lg hover:brightness-110 transition shadow-lg shadow-accent/10">
          Quiero esto para mi negocio →
        </a>
      </div>
    </div>
  </section>

  <!-- ============================= -->
  <!-- CASOS DE USO (Tabs) -->
  <!-- ============================= -->
  <section id="sectores" class="py-20 px-6 max-w-5xl mx-auto">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-4">Para cualquier negocio</h2>
    <p class="text-muted text-center mb-12 max-w-xl mx-auto">El asistente se adapta a tu sector. Sin plantillas — cada negocio es único.</p>

    <div class="flex flex-wrap justify-center gap-6 border-b border-border mb-8">
      <button class="tab-btn active text-sm font-medium pb-3 px-2 text-accent border-b-2 border-accent transition" data-tab="restaurante">Restaurante</button>
      <button class="tab-btn text-sm font-medium pb-3 px-2 text-muted hover:text-text transition" data-tab="clinica">Clínica</button>
      <button class="tab-btn text-sm font-medium pb-3 px-2 text-muted hover:text-text transition" data-tab="peluqueria">Peluquería</button>
      <button class="tab-btn text-sm font-medium pb-3 px-2 text-muted hover:text-text transition" data-tab="tienda">Tienda</button>
    </div>

    <!-- Restaurante -->
    <div class="tab-content active" id="tab-restaurante">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h3 class="text-xl font-bold mb-4">Restaurante</h3>
          <ul class="space-y-3 text-muted">
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Gestiona reservas y preguntas frecuentes (horarios, menú, alergias)</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Captura datos de contacto para confirmar y hacer seguimiento</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Atiende fuera del horario del local — incluso los lunes de cierre</li>
          </ul>
        </div>
        <div class="bg-[#0a0a09] rounded-2xl border border-border p-4 shadow-lg">
          <div class="bg-card px-3 py-2 rounded-t-lg text-xs text-muted border-b border-border">WhatsApp conversación</div>
          <div class="p-3 space-y-2 text-sm">
            <div class="flex"><div class="bg-card border border-border rounded-2xl rounded-bl-sm px-3 py-2 max-w-[85%]">Buenas, ¿qué horario tenéis?</div></div>
            <div class="flex justify-end"><div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-3 py-2 max-w-[85%]">¡Hola! Abrimos de martes a domingo de 13:00 a 16:00 y de 20:00 a 23:30. Cerramos los lunes. ¿Te ayudo con una reserva?</div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Clínica -->
    <div class="tab-content" id="tab-clinica">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h3 class="text-xl font-bold mb-4">Clínica dental</h3>
          <ul class="space-y-3 text-muted">
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Agenda y confirma citas automáticamente sin llamadas</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Resuelve dudas frecuentes sobre tratamientos y precios</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Captura leads cualificados y los envía a tu panel</li>
          </ul>
        </div>
        <div class="bg-[#0a0a09] rounded-2xl border border-border p-4 shadow-lg">
          <div class="bg-card px-3 py-2 rounded-t-lg text-xs text-muted border-b border-border">WhatsApp conversación</div>
          <div class="p-3 space-y-2 text-sm">
            <div class="flex"><div class="bg-card border border-border rounded-2xl rounded-bl-sm px-3 py-2 max-w-[85%]">Hola, quería pedir cita para una revisión dental</div></div>
            <div class="flex justify-end"><div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-3 py-2 max-w-[85%]">¡Hola! Tenemos disponible el jueves a las 17:00 o el viernes a las 10:30. ¿Cuál te va mejor?</div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Peluquería -->
    <div class="tab-content" id="tab-peluqueria">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h3 class="text-xl font-bold mb-4">Peluquería</h3>
          <ul class="space-y-3 text-muted">
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Gestiona reservas y cambios de última hora sin llamadas</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Responde dudas sobre servicios, precios y disponibilidad</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Recuerda automáticamente las citas a los clientes</li>
          </ul>
        </div>
        <div class="bg-[#0a0a09] rounded-2xl border border-border p-4 shadow-lg">
          <div class="bg-card px-3 py-2 rounded-t-lg text-xs text-muted border-b border-border">WhatsApp conversación</div>
          <div class="p-3 space-y-2 text-sm">
            <div class="flex"><div class="bg-card border border-border rounded-2xl rounded-bl-sm px-3 py-2 max-w-[85%]">Buenas, ¿tenéis hueco para un corte de pelo esta tarde?</div></div>
            <div class="flex justify-end"><div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-3 py-2 max-w-[85%]">¡Hola! Sí, tenemos un hueco a las 18:30 con María. Te llevará unos 30 min. ¿Te viene bien?</div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tienda -->
    <div class="tab-content" id="tab-tienda">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <div>
          <h3 class="text-xl font-bold mb-4">Tienda / E-commerce</h3>
          <ul class="space-y-3 text-muted">
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Consulta de stock, precios y disponibilidad de productos</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Captura leads de clientes interesados con sus datos de contacto</li>
            <li class="flex gap-3"><span class="text-accent mt-1">→</span> Atiende fuera del horario comercial sin perder ventas</li>
          </ul>
        </div>
        <div class="bg-[#0a0a09] rounded-2xl border border-border p-4 shadow-lg">
          <div class="bg-card px-3 py-2 rounded-t-lg text-xs text-muted border-b border-border">WhatsApp conversación</div>
          <div class="p-3 space-y-2 text-sm">
            <div class="flex"><div class="bg-card border border-border rounded-2xl rounded-bl-sm px-3 py-2 max-w-[85%]">Hola, ¿tenéis la chaqueta azul en talla M?</div></div>
            <div class="flex justify-end"><div class="bg-accent/10 border border-accent/20 rounded-2xl rounded-br-sm px-3 py-2 max-w-[85%]">¡Sí! Tenemos la chaqueta azul en M, 89€. ¿Te la guardamos? Pasas a recogerla o te la enviamos 😊</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================= -->
  <!-- PRECIO -->
  <!-- ============================= -->
  <section id="precio" class="py-20 px-6 bg-card/50 border-y border-border/50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">Un precio. Sin sorpresas.</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Without -->
        <div class="bg-bg border border-border rounded-2xl p-8 opacity-70">
          <h3 class="text-lg font-bold text-muted mb-6">Sin GeneraIA</h3>
          <ul class="space-y-4">
            <li class="flex gap-3 text-sm">
              <span class="text-red-500/60 mt-0.5">✕</span>
              <div>
                <p class="text-muted">Contratar personal</p>
                <p class="text-[#666] text-xs">desde 1.200€/mes</p>
              </div>
            </li>
            <li class="flex gap-3 text-sm">
              <span class="text-red-500/60 mt-0.5">✕</span>
              <div>
                <p class="text-muted">Perder clientes fuera de horario</p>
                <p class="text-[#666] text-xs">cada llamada perdida es un cliente que se va a otro</p>
              </div>
            </li>
            <li class="flex gap-3 text-sm">
              <span class="text-red-500/60 mt-0.5">✕</span>
              <div>
                <p class="text-muted">Responder los mismos mensajes cada día</p>
                <p class="text-[#666] text-xs">tu tiempo vale más que responder "¿qué horario tenéis?" 20 veces al día</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- With -->
        <div class="bg-bg border-2 border-accent/40 rounded-2xl p-8 relative">
          <div class="absolute -top-3 left-6 bg-accent text-bg text-xs font-bold px-4 py-1 rounded-full">RECOMENDADO</div>
          <h3 class="text-lg font-bold mb-2">Con GeneraIA</h3>
          <p class="text-3xl font-bold mb-6"><span class="text-accent">149€</span><span class="text-muted text-lg font-normal">/mes</span></p>
          <ul class="space-y-4">
            <li class="flex gap-3 text-sm">
              <span class="text-green-500 mt-0.5">✓</span>
              <p class="text-text">Atención 24/7 sin personal adicional</p>
            </li>
            <li class="flex gap-3 text-sm">
              <span class="text-green-500 mt-0.5">✓</span>
              <p class="text-text">Todos los leads capturados automáticamente</p>
            </li>
            <li class="flex gap-3 text-sm">
              <span class="text-green-500 mt-0.5">✓</span>
              <p class="text-text">Tú solo gestionas los que ya quieren comprar</p>
            </li>
            <li class="flex gap-3 text-sm">
              <span class="text-green-500 mt-0.5">✓</span>
              <p class="text-text">30 días gratis, sin compromiso, sin tarjeta</p>
            </li>
          </ul>
        </div>
      </div>

      <div class="text-center mt-10">
        <a href="https://wa.me/34681072103" target="_blank" rel="noopener" class="inline-block bg-accent text-bg px-10 py-4 rounded-xl font-bold text-lg hover:brightness-110 transition shadow-lg shadow-accent/20">
          Empezar los 30 días gratis
        </a>
      </div>
    </div>
  </section>

  <!-- ============================= -->
  <!-- CTA FINAL -->
  <!-- ============================= -->
  <section class="py-24 px-6 max-w-3xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-bold mb-6 leading-tight">¿Tienes 15 minutos?</h2>
    <p class="text-lg text-muted mb-10 max-w-xl mx-auto leading-relaxed">
      Cuéntame cómo es tu negocio. Si veo que puedo ayudarte, configuramos el asistente gratis durante 30 días. Sin contrato, sin riesgos.
    </p>
    <a href="https://wa.me/34681072103?text=Hola%2C%20quiero%20saber%20m%C3%A1s%20sobre%20GeneraIA" target="_blank" rel="noopener" class="inline-block bg-accent text-bg px-10 py-5 rounded-xl font-bold text-xl hover:brightness-110 transition shadow-lg shadow-accent/20 mb-4">
      Escribir por WhatsApp →
    </a>
    <p class="text-sm text-muted">o escríbeme a <a href="mailto:hola@generaia.org" class="text-text underline underline-offset-2 hover:text-accent transition">hola@generaia.org</a></p>
  </section>

  <!-- ============================= -->
  <!-- FOOTER -->
  <!-- ============================= -->
  <footer class="border-t border-border py-8 px-6">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted">
      <div class="flex items-center gap-2">
        <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="16" cy="16" r="12" stroke="#f59e0b" stroke-width="2" fill="none"/>
          <text x="16" y="22" text-anchor="middle" fill="#f59e0b" font-size="18" font-weight="700" font-family="Space Grotesk, sans-serif">G</text>
        </svg>
        <span>GeneraIA — 2026</span>
      </div>
      <div class="flex gap-6">
        <a href="mailto:hola@generaia.org" class="hover:text-text transition">hola@generaia.org</a>
        <a href="https://wa.me/34681072103" target="_blank" rel="noopener" class="hover:text-text transition">WhatsApp</a>
        <a href="https://demo.generaia.org" target="_blank" rel="noopener" class="hover:text-text transition">Dashboard</a>
      </div>
    </div>
  </footer>

  <!-- ============================= -->
  <!-- SCRIPTS -->
  <!-- ============================= -->
  <script>
    // Mobile menu toggle
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    // Tabs
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('active', 'text-accent', 'border-accent');
          b.classList.add('text-muted');
        });
        btn.classList.add('active', 'text-accent', 'border-accent');
        btn.classList.remove('text-muted');

        document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
        document.getElementById('tab-' + btn.dataset.tab)?.classList.add('active');
      });
    });
  </script>
</Layout>
