---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cómo Funciona — GeneraIA">
  <main>
    <section class="hero min-h-[70vh] flex flex-col items-center justify-center text-center relative overflow-hidden bg-[#0a0a0a]">
      <!-- Floating particles -->
      <div class="particle-container absolute inset-0 z-0">
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
      </div>

      <div class="relative z-10 p-4 max-w-4xl mx-auto">
        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white leading-tight mb-4 font-space-grotesk"
          data-animate="fade-in-up"
        >
          Cómo funciona
        </h1>
        <p
          class="text-xl md:text-2xl text-gray-300 mb-8 font-dm-sans max-w-2xl mx-auto"
          data-animate="fade-in-up"
          data-animate-delay="0.2"
        >
          En tres pasos, tu negocio empieza a vender mientras duermes
        </p>
      </div>
    </section>

    <!-- PASOS -->
    <section class="py-20 bg-[#0a0a0a] text-white">
      <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-3 gap-10">
        <!-- Paso 1 -->
        <div class="step-card p-8 rounded-2xl bg-gray-900/50 border border-white/5 text-center" data-animate="fade-in-up">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#F59E0B]/10 flex items-center justify-center">
            <span class="text-3xl">🔌</span>
          </div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#F59E0B] mb-2 block">Paso 1</span>
          <h2 class="text-2xl font-bold mb-4 font-space-grotesk">Conectamos tu WhatsApp</h2>
          <p class="text-gray-400 leading-relaxed">
            Vinculamos tu número de WhatsApp Business API con nuestra plataforma. Nosotros gestionamos toda la
            configuración técnica — tú solo nos das acceso y en horas está listo.
          </p>
        </div>

        <!-- Paso 2 -->
        <div class="step-card p-8 rounded-2xl bg-gray-900/50 border border-white/5 text-center" data-animate="fade-in-up" data-animate-delay="0.2">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#F59E0B]/10 flex items-center justify-center">
            <span class="text-3xl">🧠</span>
          </div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#F59E0B] mb-2 block">Paso 2</span>
          <h2 class="text-2xl font-bold mb-4 font-space-grotesk">Entrenamos la IA</h2>
          <p class="text-gray-400 leading-relaxed">
            Alimentamos el asistente con tus servicios, horarios, precios y preguntas frecuentes. La IA aprende a
            responder como lo haría tu mejor empleado, pero 24/7.
          </p>
        </div>

        <!-- Paso 3 -->
        <div class="step-card p-8 rounded-2xl bg-gray-900/50 border border-white/5 text-center" data-animate="fade-in-up" data-animate-delay="0.4">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#F59E0B]/10 flex items-center justify-center">
            <span class="text-3xl">💬</span>
          </div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#F59E0B] mb-2 block">Paso 3</span>
          <h2 class="text-2xl font-bold mb-4 font-space-grotesk">Atiende y vende 24/7</h2>
          <p class="text-gray-400 leading-relaxed">
            Tu asistente responde al instante, capta leads, agenda citas y resuelve dudas. Tú solo revisas el panel
            de control y te llevas los clientes.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="py-20 bg-[#0a0a0a] text-white text-center" data-animate="fade-in-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-space-grotesk">¿Listo para probarlo?</h2>
      <p class="text-gray-400 text-lg mb-8 font-dm-sans">
        30 días gratis, sin tarjeta, sin compromiso.
      </p>
      <a
        href="https://wa.me/34681072103"
        target="_blank"
        class="btn bg-[#F59E0B] text-black px-8 py-3 rounded-lg font-bold text-lg hover:bg-opacity-80 transition duration-300 inline-block"
      >
        Empezar prueba gratis
      </a>
    </section>
  </main>

  <style is:global>
    .particle-container {
      pointer-events: none;
      perspective: 500px;
    }
    .particle {
      position: absolute;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      animation: floatAndFade 15s infinite ease-in-out;
    }
    .particle:nth-child(1) { top: 10%; left: 10%; animation-duration: 12s; animation-delay: 0s; transform: scale(1.2); }
    .particle:nth-child(2) { top: 30%; left: 80%; animation-duration: 18s; animation-delay: 2s; transform: scale(0.8); }
    .particle:nth-child(3) { top: 60%; left: 20%; animation-duration: 15s; animation-delay: 4s; transform: scale(1.5); }
    .particle:nth-child(4) { top: 80%; left: 60%; animation-duration: 20s; animation-delay: 6s; transform: scale(0.9); }
    .particle:nth-child(5) { top: 40%; left: 40%; animation-duration: 10s; animation-delay: 8s; transform: scale(1.1); }
    @keyframes floatAndFade {
      0% { transform: translateY(0) rotate(0deg) scale(1) translateX(0); opacity: 0.5; }
      50% { transform: translateY(-50px) rotate(180deg) scale(1.5) translateX(20px); opacity: 0.8; }
      100% { transform: translateY(0) rotate(360deg) scale(1) translateX(0); opacity: 0.5; }
    }
    .btn {
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      font-weight: 600;
      text-decoration: none;
      display: inline-block;
    }
    [data-animate] { opacity: 0; transform: translateY(20px); }
    [data-animate="fade-in-up"] { transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
    [data-animate="fade-in-up"][data-animated] { opacity: 1; transform: translateY(0); }
    @media (max-width: 768px) {
      .hero h1 { font-size: clamp(2.5rem, 12vw, 4rem); }
      .hero p { font-size: 1.1rem; }
    }
  </style>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('[data-animate]');
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = entry.target.dataset.animateDelay || '0';
            setTimeout(() => entry.target.classList.add('data-animated'), parseFloat(delay) * 1000);
            obs.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px', threshold: 0.1 });
      elements.forEach(el => observer.observe(el));
    });
  </script>
</Layout>
