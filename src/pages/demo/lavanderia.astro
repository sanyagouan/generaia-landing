---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Demo LimpiaMax | GeneraIA">
  <section class="max-w-md mx-auto h-[calc(100vh-4rem)] flex flex-col bg-[#e5ddd5] relative rounded-xl overflow-hidden shadow-2xl">
    <div class="bg-[#075e54] text-white px-4 py-3 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-[#25d366] flex items-center justify-center text-white font-bold text-sm">LM</div>
      <div>
        <p class="font-semibold text-sm">LimpiaMax</p>
        <p class="text-[10px] opacity-80">en línea</p>
      </div>
    </div>
    <div id="chatMessages" class="flex-1 overflow-y-auto p-3 space-y-2"></div>
    <div class="bg-[#f0f0f0] px-3 py-2 flex gap-2 border-t border-[#ddd]">
      <input id="chatInput" type="text" placeholder="Escribe un mensaje..." class="flex-1 px-4 py-2.5 rounded-full border-none bg-white text-sm focus:outline-none" />
      <button id="sendBtn" class="w-11 h-11 rounded-full bg-[#075e54] text-white text-lg flex items-center justify-center hover:bg-[#054d44] transition-colors">➤</button>
    </div>
  </section>

  <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50">
    <a href="https://wa.me/34681072103?text=Hola%20GeneraIA%2C%20quiero%20esto%20en%20mi%20lavanderia" target="_blank" class="bg-[#25d366] hover:bg-[#1da851] text-white px-8 py-4 rounded-full font-semibold shadow-lg hover:shadow-xl transition-all duration-300 flex items-center gap-2 text-sm md:text-base animate-bounce-subtle">
      Quiero esto en mi negocio
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    </a>
  </div>
</Layout>

<style is:global>
  .whatsapp-msg-sent { background: #dcf8c6; border-radius: 8px 8px 2px 8px; align-self: flex-end; }
  .whatsapp-msg-recv { background: #fff; border-radius: 8px 8px 8px 2px; align-self: flex-start; }
  @keyframes bounce-subtle {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-3px); }
  }
  .animate-bounce-subtle { animation: bounce-subtle 2s ease-in-out infinite; }
</style>

<script is:inline>
(function() {
  const chat = document.getElementById('chatMessages');
  const input = document.getElementById('chatInput');
  const btn = document.getElementById('sendBtn');

  const botName = 'LimpiaMax';
  const whatsapp = 'https://wa.me/34681072103?text=Hola%20GeneraIA%2C%20quiero%20esto%20en%20mi%20lavanderia';

  const responses = [
    { p: ['lavar','lavado','kg','precio lavar'], r: 'Lavado por kilo: 8€/kg. Recogemos y entregamos en 48h. Servicio urgente disponible (24h +50%).' },
    { p: ['planchar','plancha'], r: 'Planchado: 12€/hora. Recogida y entrega a domicilio incluida para +5kg.' },
    { p: ['tintoreria','tintoreria','limpieza en seco'], r: 'Tintorería desde 12€ la prenda. Trajes, vestidos de fiesta, abrigos. Presupuesto sin compromiso.' },
    { p: ['edredon','edredon','nordico'], r: 'Edredón nórdico: 25€. Lavado y secado profesional. Recogida a domicilio sin coste adicional.' },
    { p: ['horario','abierto','hora abris','cierra'], r: 'Abiertos de lunes a sábado de 8:00 a 21:00. Domingo cerrados.' },
    { p: ['domicilio','recogida','envio','a casa'], r: 'Recogida y entrega a domicilio GRATIS para pedidos de +5kg. Servicio disponible en toda Barcelona.' },
    { p: ['urgente','rapido','cuanto tarda'], r: 'Servicio urgente (24h) con recargo del 50%. Para el mismo día, consulta disponibilidad.' },
    { p: ['estado pedido','como va','en que punto'], r: 'Dime tu número de pedido y te digo al instante cómo va tu ropa.' },
    { p: ['prenda especial','traje','vestido','gabardina'], r: 'Prendas especiales (trajes, vestidos): desde 15€. Incluye tratamiento antimanchas y entrega en perchas.' },
    { p: ['mancha','vino','aceite','cafe','barro'], r: 'Tratamiento antimanchas profesional incluido en el precio base. Consulta para manchas difíciles.' },
    { p: ['zapato','zapatilla','calzado'], r: 'Limpieza de calzado desde 10€. Deportivas, zapatos, botas.' },
    { p: ['hola','buenas','que tal'], r: '¡Hola! Soy LimpiaMax, tu tintorería de confianza. Pregúntame precios, horarios, recogida a domicilio o el estado de tu pedido.' },
    { p: ['gracias','vale','ok'], r: '¡A ti! Si necesitas algo más, estoy aquí. También puedes escribirnos directo por WhatsApp.' },
    { p: ['precio','cuanto cuesta','tarifa'], r: 'Lavado 8€/kg, planchado 12€/h, tintorería desde 12€/prenda, edredones 25€. Todo con recogida a domicilio disponible.' },
    { p: ['sabana','sabana','ropa cama'], r: 'Lavado de sábanas: pack cama individual 8€, matrimonio 12€. Incluye planchado.' },
    { p: ['toalla','toallas','albornoz'], r: 'Lavado de toallas: 1€/unidad (pedido mínimo 10 unidades para establecimientos).' },
    { p: ['uniforme','trabajo','laboral'], r: 'Lavado y planchado de uniformes laborales. Consulta tarifa para empresas.' },
    { p: ['tapiceria','sofá','sillón','coche'], r: 'Limpieza de tapicería: sofás desde 60€, sillones desde 35€, interior de coche desde 80€.' },
    { p: ['alfombra','moqueta'], r: 'Lavado de alfombras: desde 15€/m² según material. Recogida a domicilio incluida.' },
  ];

  function addMsg(text, isUser) {
    const div = document.createElement('div');
    div.className = `max-w-[80%] p-3 text-sm shadow-sm ${isUser ? 'whatsapp-msg-sent ml-auto' : 'whatsapp-msg-recv'}`;
    div.textContent = text;
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
  }

  function getBotReply(msg) {
    const m = msg.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    for (const r of responses) {
      for (const p of r.p) {
        if (m.includes(p)) return r.r;
      }
    }
    return 'En la versión completa, mi IA aprendería de tu lavandería y respondería todo automáticamente: precios exactos, seguimiento de pedidos, ofertas personalizadas. ¿Te gustaría ver cómo funcionaría en tu negocio?';
  }

  function send() {
    const msg = input.value.trim();
    if (!msg) return;
    addMsg(msg, true);
    input.value = '';
    setTimeout(() => addMsg(getBotReply(msg), false), 600);
  }

  btn.addEventListener('click', send);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') send(); });

  addMsg('¡Hola! Soy el asistente de LimpiaMax. Pregúntame por precios de lavado, plancha, tintorería, servicio a domicilio o estado de tu pedido.', false);
})();
</script>
