---
import Layout from '../layouts/Layout.astro';

const sectors = [
  { name: 'Talleres Mecánicos', icon: '🔧', description: 'Automatiza presupuestos, citas previas y consultas técnicas. Tus clientes reciben respuesta al instante.', soon: false },
  { name: 'Academias de Formación', icon: '📚', description: 'Resuelve dudas sobre horarios, precios, matriculación y niveles sin que tengas que contestar tú.', soon: false },
  { name: 'Lavanderías y Tintorerías', icon: '🧺', description: 'Gestiona pedidos, precios por kilo, recogida a domicilio y estado de las prendas.', soon: false },
  { name: 'Clínicas Dentales', icon: '🦷', description: 'Agenda citas, resuelve dudas sobre tratamientos y envía recordatorios automáticos.', soon: true },
  { name: 'Servicios a Domicilio', icon: '🚚', description: 'Coordina presupuestos, disponibilidad y visitas sin necesidad de llamadas.', soon: true },
  { name: 'Asesorías', icon: '📝', description: 'Atiende consultas fiscales y laborales frecuentes mientras tu equipo se centra en lo importante.', soon: true },
];
---

<Layout title="Sectores — GeneraIA">
  <main>
    <section class="hero min-h-[60vh] flex flex-col items-center justify-center text-center relative overflow-hidden bg-[#0a0a0a]">
      <!-- Floating particles -->
      <div class="particle-container absolute inset-0 z-0">
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
        <div class="particle bg-[#F59E0B] opacity-30"></div>
      </div>

      <div class="relative z-10 p-4 max-w-4xl mx-auto">
        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-extrabold text-white leading-tight mb-4 font-space-grotesk"
          data-animate="fade-in-up"
        >
          Sectores
        </h1>
        <p
          class="text-xl md:text-2xl text-gray-300 mb-8 font-dm-sans max-w-2xl mx-auto"
          data-animate="fade-in-up"
          data-animate-delay="0.2"
        >
          Da igual tu sector. Si atiendes clientes por WhatsApp, la IA funciona.
        </p>
      </div>
    </section>

    <!-- Grid sectores -->
    <section class="py-20 bg-[#0a0a0a] text-white">
      <div class="max-w-6xl mx-auto px-4 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sectors.map((sector) => (
          <div
            class={`sector-card p-6 rounded-2xl border transition-all duration-300 ${
              sector.soon
                ? 'bg-gray-900/30 border-white/5 opacity-60'
                : 'bg-gray-900/50 border-white/5 hover:border-[#F59E0B]/30 hover:bg-gray-900/70'
            }`}
            data-animate="fade-in-up"
          >
            <div class="flex items-start gap-4 mb-4">
              <div class="w-12 h-12 rounded-full bg-[#F59E0B]/10 flex items-center justify-center flex-shrink-0">
                <span class="text-2xl">{sector.icon}</span>
              </div>
              <div class="flex-1">
                <h2 class="text-lg font-bold font-space-grotesk">{sector.name}</h2>
                {sector.soon && (
                  <span class="inline-block mt-1 text-xs font-bold uppercase tracking-wider text-[#F59E0B] bg-[#F59E0B]/10 px-2 py-0.5 rounded-full">
                    Próximamente
                  </span>
                )}
              </div>
            </div>
            <p class="text-gray-400 text-sm leading-relaxed">{sector.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-[#0a0a0a] text-white text-center" data-animate="fade-in-up">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 font-space-grotesk">¿No ves tu sector?</h2>
      <p class="text-gray-400 text-lg mb-8 font-dm-sans">
        Da igual — si tienes clientes por WhatsApp, te ayudamos. Escríbenos y te contamos cómo.
      </p>
      <a
        href="https://wa.me/34681072103"
        target="_blank"
        class="btn bg-[#F59E0B] text-black px-8 py-3 rounded-lg font-bold text-lg hover:bg-opacity-80 transition duration-300 inline-block"
      >
        Hablemos por WhatsApp
      </a>
    </section>
  </main>

  <style is:global>
    .particle-container {
      pointer-events: none;
      perspective: 500px;
    }
    .particle {
      position: absolute;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      animation: floatAndFade 15s infinite ease-in-out;
    }
    .particle:nth-child(1) { top: 10%; left: 10%; animation-duration: 12s; animation-delay: 0s; transform: scale(1.2); }
    .particle:nth-child(2) { top: 30%; left: 80%; animation-duration: 18s; animation-delay: 2s; transform: scale(0.8); }
    .particle:nth-child(3) { top: 60%; left: 20%; animation-duration: 15s; animation-delay: 4s; transform: scale(1.5); }
    .particle:nth-child(4) { top: 80%; left: 60%; animation-duration: 20s; animation-delay: 6s; transform: scale(0.9); }
    .particle:nth-child(5) { top: 40%; left: 40%; animation-duration: 10s; animation-delay: 8s; transform: scale(1.1); }
    @keyframes floatAndFade {
      0% { transform: translateY(0) rotate(0deg) scale(1) translateX(0); opacity: 0.5; }
      50% { transform: translateY(-50px) rotate(180deg) scale(1.5) translateX(20px); opacity: 0.8; }
      100% { transform: translateY(0) rotate(360deg) scale(1) translateX(0); opacity: 0.5; }
    }
    .btn {
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      font-weight: 600;
      text-decoration: none;
      display: inline-block;
    }
    [data-animate] { opacity: 0; transform: translateY(20px); }
    [data-animate="fade-in-up"] { transition: opacity 0.6s ease-out, transform 0.6s ease-out; }
    [data-animate="fade-in-up"][data-animated] { opacity: 1; transform: translateY(0); }
    @media (max-width: 768px) {
      .hero h1 { font-size: clamp(2.5rem, 12vw, 4rem); }
      .hero p { font-size: 1.1rem; }
    }
  </style>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const elements = document.querySelectorAll('[data-animate]');
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const delay = entry.target.dataset.animateDelay || '0';
            setTimeout(() => entry.target.classList.add('data-animated'), parseFloat(delay) * 1000);
            obs.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px', threshold: 0.1 });
      elements.forEach(el => observer.observe(el));
    });
  </script>
</Layout>
